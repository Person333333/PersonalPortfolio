---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import TagList from "../components/TagList.astro";
import { getCollection } from "astro:content";

const research = await getCollection("research");
const sorted = research.sort((a, b) => b.data.year - a.data.year);
---
<BaseLayout title="Research — Nikhil V">
  <section class="section">
    <div class="container">
      <SectionTitle
        eyebrow="Research"
        title="Method-first investigations"
        description="Focused studies in respiratory audio ML, agriculture systems, and edge sensing."
      />
      <div class="grid grid-2">
        {sorted.map((item) => (
          <article class="card research-card">
            <p class="eyebrow">{item.data.year}</p>
            <h3>{item.data.title}</h3>
            <p class="subtle">{item.data.summary}</p>
            <TagList tags={item.data.methods} />
            <div class="result-list">
              {item.data.results.map((result) => (
                <p>• {result}</p>
              ))}
            </div>
            {item.data.writeup_link && (
              <a class="text-link" href={item.data.writeup_link} target="_blank" rel="noreferrer">Read write-up</a>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
