---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ProjectCard from "../components/ProjectCard.astro";
import TagList from "../components/TagList.astro";
import { getCollection, getEntry } from "astro:content";

const profile = await getEntry("profile", "site");
const projects = await getCollection("projects");
const research = await getCollection("research");
const achievements = await getCollection("achievements");
const leadership = await getCollection("leadership");

const featuredProjects = projects
  .filter((project) => project.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const topResearch = research.sort((a, b) => b.data.year - a.data.year).slice(0, 2);
const sortedAchievements = achievements.sort((a, b) => b.data.year - a.data.year);
const lead = leadership.sort((a, b) => b.data.year - a.data.year)[0];

const coursework = [
  "IB Computer Science SL",
  "IB Mathematics: Analysis & Approaches HL",
  "University of Washington: Artificial Intelligence",
  "University of Washington: Algorithms"
];
---
<BaseLayout>
  <!-- ── HERO ── -->
  <section class="section hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow fade-up">IB Diploma Candidate · Class of 2027</p>
        <h1 class="display hero-title fade-up">{profile?.data.full_name}</h1>
        <p class="hero-subtitle fade-up-delay">
          Building applied AI systems across healthcare, food security, and civic tech.
        </p>
        <div class="hero-actions fade-up-delay">
          <a class="button" href="/projects">View Projects</a>
          <a class="button ghost" href="/contact">Contact</a>
        </div>
        <div class="hero-meta fade-up-delay-2">
          <div class="meta-item">
            <p class="meta-label">Focus</p>
            <p class="meta-value">{profile?.data.intended_major}</p>
          </div>
          <div class="meta-item">
            <p class="meta-label">GPA</p>
            <p class="meta-value">{profile?.data.gpa}</p>
          </div>
          <div class="meta-item">
            <p class="meta-label">Testing</p>
            <p class="meta-value">{profile?.data.test_scores}</p>
          </div>
        </div>
      </div>
      <div class="hero-card fade-up-delay">
        <div class="hero-card-body">
          <p class="eyebrow">Current Coursework</p>
          <ul>
            {coursework.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FEATURED PROJECTS ── -->
  <section class="section">
    <div class="container">
      <SectionTitle
        eyebrow="Signature Work"
        title="Engineering projects that ship in the real world"
        description="Selected projects blending applied research, product design, and community impact."
      />
      <div class="grid grid-3">
        {featuredProjects.map((project, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <ProjectCard project={project} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── RESEARCH ── -->
  <section class="section section-accent">
    <div class="container">
      <SectionTitle
        eyebrow="Research in Focus"
        title="Method-driven ML experiments"
        description="Controlled studies and field tests with real-world implications."
      />
      <div class="grid grid-2">
        {topResearch.map((item, i) => (
          <article class={`card research-card reveal reveal-delay-${i + 1}`}>
            <p class="eyebrow">{item.data.year}</p>
            <h3>{item.data.title}</h3>
            <p class="subtle">{item.data.summary}</p>
            <TagList tags={item.data.methods} />
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── ACHIEVEMENTS ── -->
  <section class="section">
    <div class="container">
      <SectionTitle
        eyebrow="Awards & Recognition"
        title="Performance validated by competition and impact"
        description="Selected awards, placements, and honors with proof links."
      />
      <div class="grid grid-2">
        {sortedAchievements.map((item, i) => (
          <article class={`card award-card reveal reveal-delay-${(i % 3) + 1}`}>
            <p class="eyebrow">{item.data.year}</p>
            <h3>{item.data.title}</h3>
            <p class="subtle">{item.data.rank} · {item.data.organization}</p>
            {item.data.proof_link && (
              <a class="text-link" href={item.data.proof_link} target="_blank" rel="noreferrer">
                View proof ↗
              </a>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── LEADERSHIP ── -->
  <section class="section section-tight">
    <div class="container highlight reveal">
      <div>
        <p class="eyebrow">Community Impact</p>
        <h2 class="display">{lead?.data.title}</h2>
        <p class="subtle">{lead?.data.role}</p>
      </div>
      <p>{lead?.data.impact}</p>
      {lead?.data.link && (
        <a class="text-link" href={lead.data.link} target="_blank" rel="noreferrer">Visit organization ↗</a>
      )}
    </div>
  </section>
</BaseLayout>
