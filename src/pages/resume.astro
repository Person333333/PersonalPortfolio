---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { getEntry } from "astro:content";

const profile = await getEntry("profile", "site");
const skills = [
  "Python",
  "JavaScript",
  "React",
  "React Native",
  "PyTorch",
  "TensorFlow/Keras",
  "YAMNet",
  "wav2vec 2.0",
  "Git",
  "GitHub",
  "VS Code"
];
const interests = ["Edge AI", "Food Security", "Healthcare ML", "Applied ML Systems"];
const coursework = [
  "IB Computer Science SL",
  "IB Mathematics: Analysis & Approaches HL",
  "University of Washington: Artificial Intelligence",
  "University of Washington: Algorithms"
];
---
<BaseLayout title="Resume — Nikhil V">
  <section class="section">
    <div class="container">
      <SectionTitle eyebrow="Resume" title="Academic profile" />
      <div class="grid grid-2">
        <article class="card">
          <h3>Academics</h3>
          <p class="subtle">{profile?.data.school_program}</p>
          <p>Intended Major: {profile?.data.intended_major}</p>
          <p>GPA: {profile?.data.gpa}</p>
          <p>Test Scores: {profile?.data.test_scores}</p>
        </article>
        <article class="card">
          <h3>Coursework</h3>
          <ul>
            {coursework.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-accent">
    <div class="container">
      <SectionTitle eyebrow="Skills" title="Technical stack" />
      <div class="card">
        <div class="tag-list">
          {skills.map((skill) => (
            <span class="pill">{skill}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionTitle eyebrow="Interests" title="Where I want to build" />
      <div class="card">
        <div class="tag-list">
          {interests.map((interest) => (
            <span class="pill">{interest}</span>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
