---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { getCollection } from "astro:content";

const leadership = await getCollection("leadership");
const achievements = await getCollection("achievements");
const sortedLeadership = leadership.sort((a, b) => b.data.year - a.data.year);
const sortedAchievements = achievements.sort((a, b) => b.data.year - a.data.year);
---
<BaseLayout title="Impact — Nikhil V">
  <section class="section">
    <div class="container">
      <SectionTitle
        eyebrow="Impact & Leadership"
        title="Organizing real-world outcomes"
        description="Community initiatives, service leadership, and recognition for impact."
      />
      <div class="grid grid-2">
        {sortedLeadership.map((item) => (
          <article class="card">
            <p class="eyebrow">{item.data.year}</p>
            <h3>{item.data.title}</h3>
            <p class="subtle">{item.data.role}</p>
            <p>{item.data.impact}</p>
            {item.data.link && (
              <a class="text-link" href={item.data.link} target="_blank" rel="noreferrer">Visit</a>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-accent">
    <div class="container">
      <SectionTitle eyebrow="Recognition" title="Awards and placements" />
      <div class="grid grid-2">
        {sortedAchievements.map((item) => (
          <article class="card">
            <p class="eyebrow">{item.data.year}</p>
            <h3>{item.data.title}</h3>
            <p class="subtle">{item.data.rank} · {item.data.organization}</p>
            {item.data.proof_link && (
              <a class="text-link" href={item.data.proof_link} target="_blank" rel="noreferrer">Proof</a>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
